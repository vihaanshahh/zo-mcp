{
  "name": "zo-mcp",
  "version": "1.0.0",
  "description": "MCP server for texting and emailing from agents running on your Zo Computer",
  "type": "module",
  "license": "MIT",
  "author": "Vihaan Shah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vihaanshahh/zo-mcp.git"
  },
  "homepage": "https://github.com/vihaanshahh/zo-mcp#readme",
  "bugs": {
    "url": "https://github.com/vihaanshahh/zo-mcp/issues"
  },
  "keywords": [
    "zo",
    "zo-computer",
    "mcp",
    "model-context-protocol",
    "sms",
    "claude-code",
    "cursor"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "zo-mcp": "dist/index.js",
    "zo-text": "dist/zo-text.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
